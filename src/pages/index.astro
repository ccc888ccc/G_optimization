---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

// P1 首頁骨架：Hero + 3 學習路徑卡 + 9 領域網格（占位，之後接 content collection）。
const paths = [
  { key: 'undergrad', title: '大學部入門', desc: '從零建立最佳化的直覺與基本工具。', icon: '🌱' },
  { key: 'grad', title: '研究所進階', desc: '嚴謹證明、對偶、分解與隨機規劃。', icon: '🎓' },
  { key: 'review', title: '快速複習', desc: '重點公式與定理的速查式回顧。', icon: '⚡' },
];

const domains = [
  { key: 'foundations', label: '基礎數學' },
  { key: 'lp', label: '線性規劃' },
  { key: 'ip', label: '整數規劃' },
  { key: 'nlp', label: '非線性規劃' },
  { key: 'sp', label: '隨機規劃' },
  { key: 'sip', label: '隨機整數規劃' },
  { key: 'dp', label: '動態規劃' },
  { key: 'decomposition', label: '分解與對偶' },
  { key: 'tools', label: '工具與計算' },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
      <p class="font-ui mb-4 text-sm font-medium tracking-wide text-accent">
        {SITE.tagline}
      </p>
      <h1 class="max-w-3xl text-4xl font-bold leading-tight text-ink sm:text-5xl">
        把數學最佳化，講到透。
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        {SITE.description}一篇文章講透一個概念——先直覺、後嚴謹證明，配互動視覺化。
      </p>
      <div class="font-ui mt-8 flex flex-wrap gap-3">
        <a
          href="/domains"
          class="rounded bg-accent px-5 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
          style="border-radius: var(--radius-btn)"
        >
          開始閱讀
        </a>
        <a
          href="/paths"
          class="rounded border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-soft"
          style="border-radius: var(--radius-btn)"
        >
          看學習路徑
        </a>
      </div>
    </div>
  </section>

  <!-- 3 學習路徑卡 -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-semibold text-ink">三條學習路徑</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      {
        paths.map((p) => (
          <a
            href={`/paths/${p.key}`}
            class="group block rounded-lg border border-line bg-surface p-6 transition-shadow hover:shadow-[var(--shadow-card)]"
            style="border-radius: var(--radius-box)"
          >
            <span class="text-2xl">{p.icon}</span>
            <h3 class="mt-3 text-lg font-semibold text-ink group-hover:text-accent">
              {p.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{p.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 9 領域網格 -->
  <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
    <h2 class="text-2xl font-semibold text-ink">九大領域</h2>
    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3">
      {
        domains.map((d) => (
          <a
            href={`/domains/${d.key}`}
            class="font-ui rounded-lg border border-line bg-surface px-5 py-6 text-center text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
            style="border-radius: var(--radius-box)"
          >
            {d.label}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
