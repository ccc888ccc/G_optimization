---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DomainBadge from '../components/badges/DomainBadge.astro';
import { SITE } from '../config';
import { DOMAIN_LABELS, type Domain } from '../lib/taxonomy';

// P1 首頁：Hero + 3 學習路徑卡 + 精選/最新（接 content collection）+ 9 領域網格。
const paths = [
  { key: 'undergrad', title: '大學部入門', desc: '從零建立最佳化的直覺與基本工具。', icon: '🌱' },
  { key: 'grad', title: '研究所進階', desc: '嚴謹證明、對偶、分解與隨機規劃。', icon: '🎓' },
  { key: 'review', title: '快速複習', desc: '重點公式與定理的速查式回顧。', icon: '⚡' },
];

const domainKeys = Object.keys(DOMAIN_LABELS) as Domain[];

const articles = await getCollection('articles', (e) => !e.data.draft);
const sorted = [...articles].sort((a, b) => {
  const byDate = b.data.date.getTime() - a.data.date.getTime();
  return byDate !== 0 ? byDate : a.data.order - b.data.order;
});
const [featured, ...rest] = sorted;
const latest = rest.slice(0, 5);

const domainCounts = new Map<Domain, number>();
for (const a of articles) {
  domainCounts.set(a.data.domain, (domainCounts.get(a.data.domain) ?? 0) + 1);
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
      <p class="font-ui mb-4 text-sm font-medium tracking-wide text-accent">
        {SITE.tagline}
      </p>
      <h1 class="max-w-3xl text-4xl font-bold leading-tight text-ink sm:text-5xl">
        把數學最佳化，講到透。
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        {SITE.description}一篇文章講透一個概念——先直覺、後嚴謹證明，配互動視覺化。
      </p>
      <div class="font-ui mt-8 flex flex-wrap gap-3">
        <a
          href="/domains"
          class="rounded bg-accent px-5 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
          style="border-radius: var(--radius-btn)"
        >
          開始閱讀
        </a>
        <a
          href="/paths"
          class="rounded border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-soft"
          style="border-radius: var(--radius-btn)"
        >
          看學習路徑
        </a>
      </div>
    </div>
  </section>

  <!-- 3 學習路徑卡 -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-semibold text-ink">三條學習路徑</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      {
        paths.map((p) => (
          <a
            href={`/paths/${p.key}`}
            class="group block rounded-lg border border-line bg-surface p-6 transition-shadow hover:shadow-[var(--shadow-card)]"
            style="border-radius: var(--radius-box)"
          >
            <span class="text-2xl">{p.icon}</span>
            <h3 class="mt-3 text-lg font-semibold text-ink group-hover:text-accent">
              {p.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{p.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 精選 + 最新（左大右列表） -->
  {featured && (
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-semibold text-ink">精選與最新</h2>
      <div class="mt-8 grid gap-6 lg:grid-cols-[1.4fr_1fr]">
        <a
          href={`/articles/${featured.data.slug}`}
          class="group block rounded-lg border border-line bg-surface p-8 transition-shadow hover:shadow-[var(--shadow-card)]"
          style="border-radius: var(--radius-box)"
        >
          <DomainBadge domain={featured.data.domain} />
          <h3 class="mt-4 text-2xl font-bold text-ink group-hover:text-accent">{featured.data.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-muted">{featured.data.description}</p>
        </a>

        <ul class="flex flex-col divide-y divide-line rounded-lg border border-line bg-surface" style="border-radius: var(--radius-box)">
          {
            latest.map((a) => (
              <li>
                <a href={`/articles/${a.data.slug}`} class="group block px-5 py-4 transition-colors hover:bg-soft">
                  <div class="flex items-center gap-2">
                    <DomainBadge domain={a.data.domain} full={false} />
                  </div>
                  <h4 class="mt-2 text-sm font-semibold text-ink group-hover:text-accent">{a.data.title}</h4>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  )}

  <!-- 9 領域網格 -->
  <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
    <h2 class="text-2xl font-semibold text-ink">九大領域</h2>
    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3">
      {
        domainKeys.map((key) => (
          <a
            href={`/domains/${key}`}
            class="font-ui rounded-lg border border-line bg-surface px-5 py-6 text-center text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent"
            style="border-radius: var(--radius-box)"
          >
            {DOMAIN_LABELS[key]}
            {domainCounts.has(key) && <span class="ml-1.5 text-xs text-faint">({domainCounts.get(key)})</span>}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
