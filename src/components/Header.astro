---
import { SITE, NAV } from '../config';
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-line bg-bg/85 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-4 px-4 sm:px-6">
    <!-- Logo / 站名 -->
    <a href="/" class="group flex shrink-0 items-baseline gap-2">
      <span class="font-serif text-lg font-bold text-accent">{SITE.name}</span>
      <span class="font-ui hidden text-xs text-faint sm:inline">{SITE.tagline}</span>
    </a>

    <!-- 桌機主選單 -->
    <nav class="font-ui ml-auto hidden items-center gap-1 lg:flex" aria-label="主選單">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded px-3 py-2 text-sm font-medium transition-colors hover:bg-soft hover:text-accent',
              isActive(item.href) ? 'text-accent' : 'text-muted',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="ml-auto flex items-center gap-1 lg:ml-2">
      <!-- 搜尋入口（Pagefind 里程碑接上） -->
      <a
        href="/search"
        class="font-ui rounded p-2 text-muted transition-colors hover:bg-soft hover:text-accent"
        aria-label="搜尋"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <!-- 深色切換 -->
      <button
        id="theme-toggle"
        type="button"
        class="rounded p-2 text-muted transition-colors hover:bg-soft hover:text-accent"
        aria-label="切換深色模式"
      >
        <svg class="dark:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"></path>
        </svg>
        <svg class="hidden dark:block" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <!-- 手機漢堡 -->
      <button
        id="menu-toggle"
        type="button"
        class="rounded p-2 text-muted transition-colors hover:bg-soft hover:text-accent lg:hidden"
        aria-label="開啟選單"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- 手機抽屜 -->
  <nav
    id="mobile-drawer"
    class="font-ui hidden border-t border-line bg-surface px-4 py-2 lg:hidden"
    aria-label="手機主選單"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block rounded px-3 py-2.5 text-sm font-medium hover:bg-soft hover:text-accent',
            isActive(item.href) ? 'text-accent' : 'text-ink',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  // 深色切換：翻轉 .dark 並記住偏好
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // 手機抽屜開合
  const menuBtn = document.getElementById('menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  menuBtn?.addEventListener('click', () => {
    const open = drawer?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(open));
  });
</script>
